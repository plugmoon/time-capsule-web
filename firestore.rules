rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return signedIn()
        && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "superAdmin"
        );
    }

    function isHeirFor(uid) {
      return signedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/heirAccess/$(uid)/emails/$(request.auth.token.email));
    }

    match /users/{uid} {
      allow read, write: if owns(uid) || isSuperAdmin();

      match /capsules/{capsuleId} {
        allow read, write: if owns(uid);
      }

      match /inheritances/{inheritanceId} {
        allow read: if owns(uid) || isSuperAdmin() || isHeirFor(uid);
        allow write: if owns(uid) || isSuperAdmin();
      }

      match /beneficiaries/{beneficiaryId} {
        allow read, write: if owns(uid) || isSuperAdmin();
      }
    }

    match /heirAccess/{ownerUid}/emails/{email} {
      allow read: if isSuperAdmin() || (signedIn() && resource.data.email == request.auth.token.email);
      allow write: if owns(ownerUid) || isSuperAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /orders/{orderId} {
      allow create: if isSuperAdmin()
        || (signedIn() && request.resource.data.userId == request.auth.uid);
      allow read: if isSuperAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isSuperAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSuperAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isSuperAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /platform/settings {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /admins/{uid} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
